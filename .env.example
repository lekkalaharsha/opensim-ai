# ============================================================
# OpenQSim — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to Git (it is in .gitignore).
#
# Key sources:
#   NVIDIA NIM  → https://build.nvidia.com/explore  (free tier: 1,000 req/model)
#   Groq        → https://console.groq.com/keys      (free tier; rate-limited by RPM)
#   Kaggle      → https://www.kaggle.com/settings/account → "Create New Token"
# ============================================================


# ── NVIDIA NIM API ────────────────────────────────────────────────────────
# Primary key (account 1).  Used by backend/llm_advisor.py and
# nvidia_question_generator.py.
NVIDIA_API_KEY=nvapi-YOUR_PRIMARY_KEY_HERE

# Additional keys for parallel workers (each key = one extra free-tier account).
# nvidia_question_generator.py automatically uses all three if set.
NVIDIA_API_KEY_1=nvapi-YOUR_SECOND_KEY_HERE
NVIDIA_API_KEY_2=nvapi-YOUR_THIRD_KEY_HERE

# Override the advisor model (default: meta/llama-3.1-8b-instruct).
# See backend/model_catalog.py → NVIDIA_MODELS for all valid IDs.
# NVIDIA_MODEL=meta/llama-3.3-70b-instruct


# ── Groq API ─────────────────────────────────────────────────────────────
# Primary key.  Used by groq_question_generator.py.
GROQ_API_KEY=gsk_YOUR_PRIMARY_GROQ_KEY_HERE

# Additional keys for parallel workers (3 × free-tier accounts → 3 workers).
GROQ_API_KEY_1=gsk_YOUR_SECOND_GROQ_KEY_HERE
GROQ_API_KEY_2=gsk_YOUR_THIRD_GROQ_KEY_HERE

# Override the Groq model (default: llama-3.3-70b-versatile).
# See backend/model_catalog.py → GROQ_MODELS for all valid IDs.
# GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct


# ── Kaggle API ────────────────────────────────────────────────────────────
# Required for pushing benchmark results to a persistent Kaggle Dataset.
# Download kaggle.json from your Kaggle account and extract below, OR
# place kaggle.json in ~/.kaggle/kaggle.json (standard Kaggle CLI location).
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key_here
KAGGLE_NOTEBOOK=openqsim-benchmarks

# Kaggle Dataset target for sweep outputs.
OPENQSIM_KAGGLE_DATASET=/openqsim-benchmarks


# ── Local Development ─────────────────────────────────────────────────────
OPENQSIM_DATA_DIR=./data
OPENQSIM_ENVIRONMENT=development

# GitHub repo link (informational only).
GITHUB_LINK=https://github.com/lekkalaharsha/opensim-ai
